 <!-- data-tables -->
<script type="text/javascript" src="~/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" src="~/js/data-tables-script.js"></script>
<link href="~/css/jquery.dataTables.min.css" type="text/css" rel="stylesheet" media="screen,projection">
<!--DataTables example-->
<div id="table-datatables">
    <h4 class="header"></h4>
    <div class="row">
        <div class="col s12 m8 l12">
            <table id="table1" class="responsive-table display" cellspacing="0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>DNI</th>
                        <th>Hist. Clinica</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </thead>

                <tfoot>
                    <tr>
                        <th>Nombre</th>
                        <th>DNI</th>
                        <th>Hist. Clinica</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </tfoot>

                <tbody>
                    @foreach (var item in @ViewBag.Pacientes)
                    {
                        <tr>
                            <td>@item.persona.NombreCompleto</td>
                            <td>@item.persona.DNI</td>
                            <td>@item.NumeroHistoria</td>
                            <td>@item.persona.Celular</td>
                            <td>
                                <a class="btn waves-effect waves-light blue right"  data-ajax="true" href='@Url.Action("Mantener","Atencion",new { id=@item.PacienteId})'>
                                    VER <i class="mdi-action-visibility right"></i>
                                </a>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>
<br>
<div class="divider"></div>
<!--DataTables example Row grouping-->
@section scripts{
    <script type="text/javascript">
       
    </script>
}