@section scripts{
    <script>
        $(function(){
            $("#cboExamen").change(function(){
                vmedico.CargarTablaExamen($("#cboExamen").val());
                // console.log($("#cboExamen").val());
            });
        });
        var vmedico = new Vue({
            el: 'main',
            data: {
                atencion: {},
                AtencionId: @ViewBag.AtencionId,
                txtDiagnostico:"",
                txtTratamiento:"",
                TablaExamen:[],
                Examenes:[],
                TablaLaboratorios:[],
                paciente:{}
            },
            created: function () {
                var self = this;
                $.get('@Url.Action("Obtener", "Consulta")', { atencionId: self.AtencionId }, function (d) {
                    self.atencion = d;
                    self.paciente = d.paciente;
                    //console.log(self.atencion);
                });

                this.CargarExamenes();

            },
            methods: {
                CargarTablaExamen: function (tablaId) {
                    var self = this;
                    $.get('@Url.Action("ListarTablaExamen", "Consulta")', { tablaId: tablaId }, function (d) {
                        self.TablaExamen = d;
                    });
                },
                CargarExamenes: function (tablaId) {
                    var self = this;
                    $.get('@Url.Action("ListarExamenes", "Consulta")', { atencionId: self.AtencionId }, function (d) {
                        self.Examenes = d;
                    });
                },
                ListarTablaLab: function () {
                    var self = this;
                    $.get('@Url.Action("ListarTablaLaboratorios", "Consulta")', { }, function (d) {
                        for (var i = 0; i < d.length; i++) {
                            d[i].IndLab=false;
                        }
                        self.TablaLaboratorios = d;
                    });
                },
                CrearExamen:function(){
                    for (var i = 0; i < this.TablaExamen.length; i++) {
                        this.TablaExamen[i].AtencionId=this.AtencionId;
                    }
                    var self = this;
                    $.post('@Url.Action("CrearExamen", "Consulta")', { examen: this.TablaExamen }, function (d) {
                        fn.mensaje("Se Guardó el Exámen con éxito");
                        self.CargarExamenes();
                        $('#modalExamen').closeModal();
                    });
                },
                CrearOrdenLab:function(){
                    var self = this;
                    $.post('@Url.Action("CrearOrdenLab", "Consulta")', {pAtencionid:this.AtencionId, examen: this.TablaLaboratorios.filter((lab)=>lab.IndLab) }, function (d) {
                        fn.mensaje("Se Guardó el Exámen con éxito");
                        self.CargarExamenes();
                        $('#modalLaboratorio').closeModal();
                    });
                },
                EliminarExamen:function(t){
                    swal({
                        title: 'Estas Seguro de eliminar?',
                        text: "Esta operación es irreversible!",
                        type: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Si, Eliminar!'
                    }).then((result) => {
                        var self = this;
                        $.post('@Url.Action("EliminarExamen", "Consulta")', {pAtencionid:self.AtencionId, pExamenId: t}, function (d) {
                            self.Examenes = self.Examenes.filter((examen)=>examen.TablaId!=t);
                            // fn.mensaje("Se Eliminó el Exámen con éxito");
                            swal(
                              'Eliminado!',
                              'Tu registro se ha eliminado.',
                              'success'
                            )
                        });
                    })
                },
                DialogoExamen: function () {
                    $('#modalExamen').openModal();
                    this.CargarTablaExamen($("#cboExamen").val());
                },
                DialogoLaboratorio: function () {
                    $('#modalLaboratorio').openModal();
                    this.ListarTablaLab();
                },
                FiltrarTabla(lab){
                    return lab?this.Examenes.filter((examen)=>examen.ItemId==0 && examen.Valor=='P' ):this.Examenes.filter((examen)=>examen.ItemId==0 && examen.Valor!='P');
                },
                FiltrarItems(tabla){
                    return this.Examenes.filter((detalle)=>detalle.ItemId>0 && detalle.TablaId==tabla);
                }
            },
            computed:{

            }
        })
    </script>
}