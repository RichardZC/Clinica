@model BE.medico
    <h5>@Model.persona.NombreCompleto - @Model.especialidad.Denominacion </h5>
<div id="email-list" class="col s12 m12 l12 card-panel z-depth-1">
    <ul class="collection">
        @{ int i = 0;}
        @foreach (var item in ViewBag.listaCitas)
        {
            if (item.Estado)
            {
                i++;
                <li class="collection-item avatar @if (i == 1) {<text>selected</text>}"
                    ondblclick="window.location = '@Url.Action("Mantener", "Cita")' + '/' + @item.CitaId;"
                    onclick="$(this).addClass('selected').siblings().removeClass('selected');">
                    <span class="circle light-blue">@item.paciente.persona.NombreCompleto.Substring(0, 1)</span>
                    <span class="email-title">@item.paciente.persona.NombreCompleto</span>
                    <p class="truncate grey-text ultra-small">Historia Clinica: @item.paciente.NumeroHistoria</p>
                    <a class="secondary-content email-time"><span class="blue-text ultra-small">N°: @item.NumeroAtencion Hora: @item.HoraProbable</span></a>
                </li>
            }
        }
    </ul>

</div>